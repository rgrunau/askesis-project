---
interface Props {
  title:            string;
  date:             string;       // ISO string ("2025-04-15") or "Month YYYY"
  slug:             string;
  description?:     string;       // one-line excerpt
  readingTime?:     string;       // e.g. "5 min read"
  showDescription?: boolean;
}

const {
  title,
  date,
  slug,
  description,
  readingTime,
  showDescription = false,
} = Astro.props;

/**
 * Format a date string for display.
 * Accepts ISO ("2025-04-15") or already-formatted ("April 2025") strings.
 */
function formatDate(raw: string): string {
  // If it's already a human-readable string, return as-is
  if (!/^\d{4}-\d{2}-\d{2}/.test(raw)) return raw;
  // Parse ISO date — use noon UTC to avoid off-by-one from timezone shifts
  const d = new Date(raw + 'T12:00:00Z');
  return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

const displayDate = formatDate(date);
---

<a href={`/essays/${slug}`} class="essay-card">
  <div class="card-left">
    <span class="card-title">{title}</span>
    {showDescription && description && (
      <span class="card-description">{description}</span>
    )}
    <span class="card-meta">
      {displayDate}
      {readingTime && <span class="card-reading-time"> · {readingTime}</span>}
    </span>
  </div>
  <span class="card-arrow" aria-hidden="true">→</span>
</a>

<style>
  .essay-card {
    display:         flex;
    justify-content: space-between;
    align-items:     center;
    border-top:      0.5px solid var(--color-cream-08);
    padding:         1.5rem 0;
    gap:             1.5rem;
    transition:      opacity 0.15s ease;
  }

  .essay-card:hover {
    opacity: 0.75;
  }

  .card-left {
    display:        flex;
    flex-direction: column;
    gap:            0.35rem;
    min-width:      0;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size:   1.15rem;
    font-weight: 400;
    color:       var(--color-cream);
    line-height: 1.3;
  }

  .card-description {
    font-family:  var(--font-serif);
    font-size:    0.95rem;
    line-height:  1.55;
    color:        var(--color-cream-60);  /* 5.63:1 ✓ AA */
    font-style:   italic;
  }

  .card-meta {
    font-family:    var(--font-sans);
    font-size:      11px;
    font-weight:    300;
    color:          var(--color-cream-55);  /* 4.92:1 ✓ AA */
    letter-spacing: 0.04em;
  }

  .card-reading-time {
    color: var(--color-cream-55);  /* 4.92:1 ✓ AA */
  }

  .card-arrow {
    color:       var(--color-cream-20);
    font-size:   1rem;
    flex-shrink: 0;
  }
</style>
