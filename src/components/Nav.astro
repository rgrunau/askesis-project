---
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header style="position: sticky; top: 0; z-index: 50; background: rgba(243,239,230,0.82); backdrop-filter: saturate(140%) blur(10px); -webkit-backdrop-filter: saturate(140%) blur(10px); border-bottom: 1px solid rgba(26,23,20,0.10);">
  <div class="wrapper" style="height: 78px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">
    <a href="/" style="display: flex; align-items: center; gap: 14px; text-decoration: none; color: inherit;">
      <img src="/enso.png" alt="The Askesis Project" style="width: 38px; height: 38px; object-fit: contain; display: block;" />
      <span style="font-size: 18px; letter-spacing: 0.02em; font-weight: 500; white-space: nowrap;">The Askesis Project</span>
    </a>
    <nav style="display: flex; align-items: center; gap: 4px;">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="nav-link"
          aria-current={currentPage === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://askesisproject.substack.com"
        target="_blank"
        rel="noopener"
        class="btn-primary"
        style="margin-left: 10px; padding: 8px 16px; font-size: 13px; letter-spacing: 0.04em;"
      >
        Substack&nbsp;↗
      </a>
    </nav>
  </div>
</header>
