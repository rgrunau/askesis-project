---
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header style="position: sticky; top: 0; z-index: 50; background: rgba(243,239,230,0.82); backdrop-filter: saturate(140%) blur(10px); -webkit-backdrop-filter: saturate(140%) blur(10px); border-bottom: 1px solid rgba(26,23,20,0.10);">
  <div class="wrapper" style="height: 78px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">
    <a href="/" style="display: flex; align-items: center; gap: 14px; text-decoration: none; color: inherit;">
      <img src="/enso.png" alt="The Askesis Project" style="width: 38px; height: 38px; object-fit: contain; display: block;" />
      <span style="font-size: 18px; letter-spacing: 0.02em; font-weight: 500; white-space: nowrap;">The Askesis Project</span>
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-nav" style="display: flex; align-items: center; gap: 4px;">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="nav-link"
          aria-current={currentPage === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://askesisproject.substack.com"
        target="_blank"
        rel="noopener"
        class="btn-primary"
        style="margin-left: 10px; padding: 8px 16px; font-size: 13px; letter-spacing: 0.04em;"
      >
        Substack&nbsp;↗
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" aria-label="Open menu" style="display: none; background: none; border: none; padding: 8px; cursor: pointer; color: #1a1714;">
      <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="3" y1="7" x2="21" y2="7"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="17" x2="21" y2="17"/>
      </svg>
      <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" style="display: none;">
        <line x1="4" y1="4" x2="20" y2="20"/>
        <line x1="20" y1="4" x2="4" y2="20"/>
      </svg>
    </button>
  </div>
</header>

<!-- Backdrop -->
<div id="drawer-backdrop" style="display: none; position: fixed; inset: 0; background: rgba(26,23,20,0.3); z-index: 40; backdrop-filter: blur(2px);"></div>

<!-- Slide-in drawer -->
<div id="nav-drawer" style="position: fixed; top: 0; right: 0; height: 100%; width: 280px; background: #f3efe6; z-index: 50; transform: translateX(100%); transition: transform 0.3s ease; display: flex; flex-direction: column; padding: 0 0 40px;">
  <!-- Drawer header -->
  <div style="height: 78px; display: flex; align-items: center; justify-content: space-between; padding: 0 28px; border-bottom: 1px solid rgba(26,23,20,0.10);">
    <span style="font-family: 'Spline Sans Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #8a8175;">Menu</span>
    <button id="drawer-close" aria-label="Close menu" style="background: none; border: none; padding: 8px; cursor: pointer; color: #1a1714;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="4" y1="4" x2="20" y2="20"/>
        <line x1="20" y1="4" x2="4" y2="20"/>
      </svg>
    </button>
  </div>
  <!-- Drawer links -->
  <nav style="display: flex; flex-direction: column; padding: 32px 28px; gap: 4px; flex: 1;">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="drawer-link"
        aria-current={currentPage === link.href ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </nav>
  <!-- Substack CTA at bottom of drawer -->
  <div style="padding: 0 28px;">
    <a
      href="https://askesisproject.substack.com"
      target="_blank"
      rel="noopener"
      class="btn-primary"
      style="display: block; text-align: center; padding: 14px; font-size: 13px; letter-spacing: 0.04em;"
    >
      Read on Substack&nbsp;↗
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const drawer = document.getElementById('nav-drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const closeBtn = document.getElementById('drawer-close');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function openDrawer() {
    drawer!.style.transform = 'translateX(0)';
    backdrop!.style.display = 'block';
    iconOpen!.style.display = 'none';
    iconClose!.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer!.style.transform = 'translateX(100%)';
    backdrop!.style.display = 'none';
    iconOpen!.style.display = 'block';
    iconClose!.style.display = 'none';
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
</script>

<style>
  .drawer-link {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    color: #1a1714;
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid rgba(26,23,20,0.08);
    letter-spacing: -0.01em;
  }
  .drawer-link:hover { color: #a35c41; }
  .drawer-link[aria-current="page"] { color: #a35c41; }

  @media (max-width: 640px) {
    .desktop-nav { display: none !important; }
    #menu-toggle { display: block !important; }
  }
</style>
