---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Support — The Askesis Project"
  description="Support The Askesis Project. Reader-funded, no account required."
>
  <Nav />

  <main>
    <section class="support-content">
      <span class="section-label">Support</span>
      <h1>Keep this work going</h1>

      <div class="body-text">
        <p>
          The Askesis Project is entirely reader-supported. There are no
          sponsors, no affiliate links, and no algorithmic considerations
          shaping what gets written. That freedom is only possible because of
          readers who find the work worthwhile enough to pay for it directly.
        </p>
        <p>
          If these essays have been useful to you — or if you simply want to
          see more of them — consider making a contribution. Any amount is
          welcome, and nothing is behind a paywall.
        </p>
      </div>

      <div class="support-cta">
        <!-- Replace href with your Stripe Payment Link -->
        <a href="#" class="btn-primary">Support the project</a>
        <p class="support-note">No account required. One-time or recurring.</p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .support-content {
    max-width: 580px;
    margin:    0 auto;
    padding:   6rem 2.5rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size:   2.2rem;
    font-weight: 400;
    line-height: 1.2;
    margin:      0.75rem 0 2.5rem;
  }

  .body-text p {
    font-family: var(--font-serif);
    font-size:   1.15rem;
    line-height: 1.85;
    color:       var(--color-cream-72);
  }

  .body-text p + p {
    margin-top: 1.5rem;
  }

  .support-cta {
    display:        flex;
    flex-direction: column;
    align-items:    flex-start;
    gap:            1rem;
    margin-top:     3rem;
  }

  .support-note {
    font-family:    var(--font-sans);
    font-size:      11px;
    font-weight:    300;
    letter-spacing: 0.04em;
    color:          var(--color-cream-55);  /* 4.92:1 ✓ AA */
  }

  @media (max-width: 600px) {
    .support-content {
      padding: 4rem 1.5rem;
    }

    h1 {
      font-size: 1.9rem;
    }
  }
</style>
