---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Practice — The Askesis Project" currentPage="/practice">

  <!-- HEADER -->
  <section>
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 64px;">
      <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase; color: #a35c41; margin-bottom: 30px;">Practice</div>
      <h1 style="font-size: 64px; line-height: 1.06; font-weight: 400; letter-spacing: -0.018em; margin: 0 0 24px; max-width: 820px; text-wrap: balance;">Two ways to work the practice with me.</h1>
      <p style="font-size: 20px; line-height: 1.6; color: #4a443c; max-width: 600px; margin: 0;">From reading along on Substack to standing across the table from each other. Start anywhere; the work is the same.</p>
    </div>
  </section>

  <!-- OFFERINGS -->
  <section>
    <div class="wrapper" style="padding-bottom: 96px;">

      <!-- Offering i: 1:1 Coaching -->
      <div class="offering-row" style="display: grid; grid-template-columns: 90px 1fr 300px; gap: 44px; align-items: start; padding: 52px 0; border-top: 1px solid rgba(26,23,20,0.14);">
        <div style="font-family: 'Newsreader', serif; font-style: italic; font-size: 40px; color: #a35c41; line-height: 1;">i</div>
        <div style="max-width: 560px;">
          <h2 style="font-size: 34px; font-weight: 500; letter-spacing: -0.015em; margin: 0 0 8px;">1:1 Coaching</h2>
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8175; margin-bottom: 20px;">Private · by application</div>
          <p style="font-size: 18px; line-height: 1.7; color: #4a443c; margin: 0 0 24px;">The core of the work. We meet regularly over a season of your life to design, run, and repair a practice that fits the person you actually are — movement, attention, and the habits that compound into character. Equal parts accountability, strategy, and company on the road.</p>
          <a href="/contact" class="btn-dark">Apply to work together</a>
        </div>
        <div class="meta-col" style="font-family: 'Spline Sans Mono', monospace; font-size: 13px; line-height: 1.85; color: #4a443c; border-left: 1px solid rgba(26,23,20,0.14); padding-left: 24px;">
          <div style="font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #8a8175; margin-bottom: 12px;">The shape of it</div>
          Weekly or biweekly sessions<br>
          Voice and message between<br>
          A 3-month minimum<br>
          Limited spots open at a time
        </div>
      </div>

      <!-- Offering ii: The Writing -->
      <div class="offering-row" style="display: grid; grid-template-columns: 90px 1fr 300px; gap: 44px; align-items: start; padding: 52px 0; border-top: 1px solid rgba(26,23,20,0.14);">
        <div style="font-family: 'Newsreader', serif; font-style: italic; font-size: 40px; color: #a35c41; line-height: 1;">ii</div>
        <div style="max-width: 560px;">
          <h2 style="font-size: 34px; font-weight: 500; letter-spacing: -0.015em; margin: 0 0 8px;">The Writing</h2>
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8175; margin-bottom: 20px;">Free · on Substack</div>
          <p style="font-size: 18px; line-height: 1.7; color: #4a443c; margin: 0 0 24px;">The open notebook — the thinking the coaching is built on, written as it happens. Long-form essays plus a short note most Sundays on what I'm training, reading, and getting wrong. Free to read; subscribe to follow along.</p>
          <a href="https://askesisproject.substack.com" target="_blank" rel="noopener" class="btn-dark">Read on Substack ↗</a>
        </div>
        <div class="meta-col" style="font-family: 'Spline Sans Mono', monospace; font-size: 13px; line-height: 1.85; color: #4a443c; border-left: 1px solid rgba(26,23,20,0.14); padding-left: 24px;">
          <div style="font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #8a8175; margin-bottom: 12px;">What to expect</div>
          New essays, as they come<br>
          A weekly note, most Sundays<br>
          Free to read — no paywall<br>
          Reply-able — I read them all
        </div>
      </div>

      <!-- Offering iii: Further Reading -->
      <div class="offering-row" style="display: grid; grid-template-columns: 90px 1fr 300px; gap: 44px; align-items: start; padding: 52px 0; border-top: 1px solid rgba(26,23,20,0.14);">
        <div style="font-family: 'Newsreader', serif; font-style: italic; font-size: 40px; color: #a35c41; line-height: 1;">iii</div>
        <div style="max-width: 560px;">
          <h2 style="font-size: 34px; font-weight: 500; letter-spacing: -0.015em; margin: 0 0 8px;">Further Reading</h2>
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8175; margin-bottom: 20px;">Free · reference material</div>
          <p style="font-size: 18px; line-height: 1.7; color: #4a443c; margin: 0 0 24px;">Foundational texts that inform the practice — starting with the Ogilvy & Mather manual on the art of creative discipline. More will be added over time. Free to read.</p>
          <a href="https://divine-discontent.vercel.app" target="_blank" rel="noopener" class="btn-dark">Read: Divine Discontentment ↗</a>
        </div>
        <div class="meta-col" style="font-family: 'Spline Sans Mono', monospace; font-size: 13px; line-height: 1.85; color: #4a443c; border-left: 1px solid rgba(26,23,20,0.14); padding-left: 24px;">
          <div style="font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #8a8175; margin-bottom: 12px;">In this collection</div>
          Divine Discontentment<br>
          Ogilvy & Mather, 1965<br>
          More titles coming
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
@media (max-width: 1024px) {
  h1 { font-size: 46px !important; }
  .offering-row {
    grid-template-columns: 60px 1fr !important;
  }
  .meta-col {
    grid-column: 2 / -1 !important;
    border-left: none !important;
    border-top: 1px solid rgba(26,23,20,0.14) !important;
    padding-left: 0 !important;
    padding-top: 20px !important;
  }
}
@media (max-width: 640px) {
  h1 { font-size: 36px !important; }
  .offering-row {
    grid-template-columns: 1fr !important;
    gap: 20px !important;
  }
  .meta-col {
    grid-column: 1 !important;
  }
}
</style>
