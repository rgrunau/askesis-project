---
import BaseLayout from '../layouts/BaseLayout.astro';
import { practicePageCopy, offerings } from '../data/practice';
---

<BaseLayout title="Practice — The Askesis Project" currentPage="/practice">

  <!-- HEADER -->
  <section>
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 64px;">
      <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase; color: #a35c41; margin-bottom: 30px;">{practicePageCopy.eyebrow}</div>
      <h1 style="font-size: 64px; line-height: 1.06; font-weight: 400; letter-spacing: -0.018em; margin: 0 0 24px; max-width: 820px; text-wrap: balance;">{practicePageCopy.heading}</h1>
      <p style="font-size: 20px; line-height: 1.6; color: #4a443c; max-width: 600px; margin: 0;">{practicePageCopy.subheading}</p>
    </div>
  </section>

  <!-- OFFERINGS -->
  <section>
    <div class="wrapper" style="padding-bottom: 96px;">
      {offerings.map((o) => (
        <div class="offering-row" style="display: grid; grid-template-columns: 90px 1fr 300px; gap: 44px; align-items: start; padding: 52px 0; border-top: 1px solid rgba(26,23,20,0.14);">
          <div style="font-family: 'Newsreader', serif; font-style: italic; font-size: 40px; color: #a35c41; line-height: 1;">{o.numeral}</div>
          <div style="max-width: 560px;">
            <h2 style="font-size: 34px; font-weight: 500; letter-spacing: -0.015em; margin: 0 0 8px;">{o.title}</h2>
            <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8175; margin-bottom: 20px;">{o.tag}</div>
            <p style="font-size: 18px; line-height: 1.7; color: #4a443c; margin: 0 0 24px;">{o.body}</p>
            <a
              href={o.cta.href}
              class="btn-dark"
              target={o.cta.external ? '_blank' : undefined}
              rel={o.cta.external ? 'noopener' : undefined}
            >{o.cta.label}</a>
          </div>
          <div class="meta-col" style="font-family: 'Spline Sans Mono', monospace; font-size: 13px; line-height: 1.85; color: #4a443c; border-left: 1px solid rgba(26,23,20,0.14); padding-left: 24px;">
            <div style="font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: #8a8175; margin-bottom: 12px;">{o.metaLabel}</div>
            {o.meta.map((line) => <div>{line}</div>)}
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
@media (max-width: 1024px) {
  h1 { font-size: 46px !important; }
  .offering-row { grid-template-columns: 60px 1fr !important; }
  .meta-col {
    grid-column: 2 / -1 !important;
    border-left: none !important;
    border-top: 1px solid rgba(26,23,20,0.14) !important;
    padding-left: 0 !important;
    padding-top: 20px !important;
  }
}
@media (max-width: 640px) {
  h1 { font-size: 36px !important; }
  .offering-row { grid-template-columns: 1fr !important; gap: 20px !important; }
  .meta-col { grid-column: 1 !important; }
}
</style>
