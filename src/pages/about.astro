---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutPageCopy, story, founderCaption, symbol, isIs } from '../data/about';
---

<BaseLayout title="About — The Askesis Project" currentPage="/about">

  <!-- HEADER -->
  <section>
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 72px;">
      <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase; color: #a35c41; margin-bottom: 30px;">{aboutPageCopy.eyebrow}</div>
      <h1 style="font-size: 64px; line-height: 1.06; font-weight: 400; letter-spacing: -0.018em; margin: 0; max-width: 880px; text-wrap: balance;">{aboutPageCopy.heading}</h1>
    </div>
  </section>

  <!-- STORY + PORTRAIT -->
  <section>
    <div class="wrapper" style="padding-bottom: 96px;">
      <div class="story-grid" style="display: grid; grid-template-columns: 1fr 420px; gap: 64px; align-items: start;">
        <div style="max-width: 620px;">
          {story.map((para, i) => (
            <p
              style={`font-size: ${i === 0 ? '21px' : '18px'}; line-height: ${i === 0 ? '1.6' : '1.7'}; color: ${i === 0 ? '#2a2620' : '#4a443c'}; margin: 0 0 ${i === story.length - 1 ? '0' : '22px'};`}
              set:html={para}
            />
          ))}
        </div>
        <div>
          <div style="border: 1px solid rgba(26,23,20,0.14); aspect-ratio: 4/5; overflow: hidden;">
            <img src="/founder.jpg" alt="The founder of The Askesis Project" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
          </div>
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; color: #8a8175; margin-top: 14px; line-height: 1.6;">{founderCaption}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE SYMBOL -->
  <section style="background: #1a1714; color: #ece5d6;">
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="symbol-grid" style="display: grid; grid-template-columns: 240px 1fr; gap: 56px; align-items: start;">
        <div>
          <img src="/enso.png" alt="" aria-hidden="true" style="width: 150px; height: 150px; object-fit: contain; filter: invert(1); opacity: 0.92;" />
        </div>
        <div style="max-width: 720px;">
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: #c98a6e; margin-bottom: 24px;">{symbol.eyebrow}</div>
          <p style="font-size: 28px; line-height: 1.5; font-weight: 300; margin: 0 0 26px; text-wrap: pretty;" set:html={symbol.lead} />
          <p style="font-size: 18px; line-height: 1.7; color: #b3aa9b; margin: 0;" set:html={symbol.body} />
        </div>
      </div>
    </div>
  </section>

  <!-- THIS IS / ISN'T -->
  <section>
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="is-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(26,23,20,0.12); border: 1px solid rgba(26,23,20,0.12);">
        <div style="background: #f3efe6; padding: 46px 40px;">
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: #6f675b; margin-bottom: 28px;">{isIs.isLabel}</div>
          {isIs.isList.map((item) => (
            <p style="font-size: 19px; line-height: 1.5; margin: 0 0 16px; padding-left: 26px; text-indent: -26px;">
              <span style="color: #a35c41;">→&nbsp;&nbsp;</span>{item}
            </p>
          ))}
        </div>
        <div style="background: #efe9dd; padding: 46px 40px;">
          <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: #6f675b; margin-bottom: 28px;">{isIs.isntLabel}</div>
          {isIs.isntList.map((item) => (
            <p style="font-size: 19px; line-height: 1.5; margin: 0 0 16px; padding-left: 26px; text-indent: -26px; color: #6f675b;">
              <span style="color: #b0a698;">—&nbsp;&nbsp;</span>{item}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
@media (max-width: 1024px) {
  h1 { font-size: 46px !important; }
  .story-grid { grid-template-columns: 1fr !important; }
  .symbol-grid { grid-template-columns: 1fr !important; }
  .is-grid { grid-template-columns: 1fr !important; }
}
@media (max-width: 640px) {
  h1 { font-size: 36px !important; }
}
</style>
