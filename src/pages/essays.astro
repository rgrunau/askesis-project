---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EssayCard from '../components/EssayCard.astro';
import DonateStrip from '../components/DonateStrip.astro';
import { getAllPosts } from '../data/essays';

// Fetch all posts from Substack RSS at build time
const posts = await getAllPosts();
---

<BaseLayout
  title="Essays — The Askesis Project"
  description="All essays on self-cultivation, attention, practice, and the examined life."
>
  <Nav />

  <main>
    <!-- ── Page hero ───────────────────────────────────────── -->
    <section class="page-hero">
      <span class="section-label">The archive</span>
      <h1>Essays</h1>
      <p class="page-lede">
        Explorations of ancient and modern practice — philosophy put to use.
      </p>
    </section>

    <!-- ── Essay list ──────────────────────────────────────── -->
    <section class="essays-list">
      <div class="essays-inner">
        {posts.length > 0 ? (
          posts.map((post) => (
            <EssayCard
              title={post.title}
              date={post.date}
              slug={post.slug}
              description={post.excerpt}
              readingTime={post.readingTime}
              showDescription={true}
            />
          ))
        ) : (
          <p class="empty-state">
            No essays found. The feed may be unavailable — check back soon.
          </p>
        )}
      </div>
    </section>

    <DonateStrip />
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    max-width: var(--max-width);
    margin:    0 auto;
    padding:   5rem 2.5rem 3rem;
  }

  .page-hero h1 {
    font-family:  var(--font-serif);
    font-size:    2.5rem;
    font-weight:  400;
    line-height:  1.18;
    margin:       0.75rem 0 1rem;
  }

  .page-lede {
    font-family: var(--font-serif);
    font-size:   1.1rem;
    line-height: 1.75;
    color:       var(--color-cream-55);
  }

  .essays-list {
    max-width: var(--max-width);
    margin:    0 auto;
    padding:   0 2.5rem 5rem;
  }

  .essays-inner {
    display:        flex;
    flex-direction: column;
  }

  .empty-state {
    font-family:  var(--font-serif);
    font-size:    1rem;
    line-height:  1.75;
    color:        var(--color-cream-55);  /* 4.92:1 ✓ AA */
    padding:      2rem 0;
  }

  @media (max-width: 600px) {
    .page-hero {
      padding: 3rem 1.5rem 2rem;
    }

    .essays-list {
      padding: 0 1.5rem 4rem;
    }
  }
</style>
