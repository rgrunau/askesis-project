---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hero, definition, pillars } from '../data/home';
---

<BaseLayout title="The Askesis Project" currentPage="/">

  <!-- HERO -->
  <section style="position: relative; overflow: hidden;">
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 120px;">
      <img src="/enso.png" alt="" aria-hidden="true" class="enso-watermark" style="position: absolute; top: 50%; right: 40px; transform: translateY(-50%); width: 620px; height: 620px; object-fit: contain; pointer-events: none;" />
      <div style="position: relative; max-width: 760px;">
        <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.32em; text-transform: uppercase; color: #a35c41; margin-bottom: 30px;" set:html={hero.eyebrow} />
        <h1 style="font-size: 78px; line-height: 1.04; font-weight: 400; letter-spacing: -0.018em; margin: 0 0 32px; text-wrap: balance;" set:html={hero.heading.replace('\n', '<br>')} />
        <p style="font-size: 22px; line-height: 1.55; color: #4a443c; max-width: 560px; margin: 0 0 44px;">{hero.body}</p>
        <div style="display: flex; flex-wrap: wrap; gap: 16px;">
          {hero.ctas.map((cta) => (
            <a
              href={cta.href}
              class={cta.external ? 'btn-outline' : 'btn-primary'}
              target={cta.external ? '_blank' : undefined}
              rel={cta.external ? 'noopener' : undefined}
            >{cta.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- DEFINITION -->
  <section style="border-top: 1px solid rgba(26,23,20,0.10); background: #efe9dd;">
    <div class="wrapper" style="padding-top: 88px; padding-bottom: 88px;">
      <div class="definition-grid" style="display: grid; grid-template-columns: 220px 1fr; gap: 56px; align-items: start;">
        <div style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; color: #6f675b; padding-top: 14px;">{definition.label}</div>
        <div style="max-width: 720px;">
          <p style="font-size: 30px; line-height: 1.45; font-weight: 400; margin: 0 0 28px; letter-spacing: -0.01em; text-wrap: pretty;" set:html={definition.lead} />
          <p style="font-size: 19px; line-height: 1.65; color: #4a443c; margin: 0; max-width: 600px;">{definition.body}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PILLARS -->
  <section>
    <div class="wrapper" style="padding-top: 96px; padding-bottom: 96px;">
      <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 24px; margin-bottom: 56px; border-bottom: 1px solid rgba(26,23,20,0.12); padding-bottom: 22px;">
        <h2 style="font-size: 17px; font-family: 'Spline Sans Mono', monospace; font-weight: 500; letter-spacing: 0.04em; margin: 0; text-transform: uppercase; color: #1a1714;">{pillars.heading}</h2>
        <span style="font-family: 'Spline Sans Mono', monospace; font-size: 12px; color: #6f675b; letter-spacing: 0.04em;">{pillars.subheading}</span>
      </div>
      <div class="pillars-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(26,23,20,0.12); border: 1px solid rgba(26,23,20,0.12);">
        {pillars.items.map((p) => (
          <div style="background: #f3efe6; padding: 40px 34px 46px; min-height: 280px;">
            <div style="font-family: 'Newsreader', serif; font-size: 40px; color: #a35c41; margin-bottom: 24px; line-height: 1;">{p.glyph}</div>
            <h3 style="font-size: 26px; font-weight: 500; margin: 0 0 6px; letter-spacing: -0.01em;">{p.title}</h3>
            <div style="font-family: 'Spline Sans Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #8a8175; margin-bottom: 18px;">{p.greek}</div>
            <p style="font-size: 17px; line-height: 1.6; color: #4a443c; margin: 0;">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.enso-watermark { opacity: 0.8; }
@media (max-width: 640px) {
  .enso-watermark { opacity: 0.10; }
}
@media (max-width: 1024px) {
  .definition-grid { grid-template-columns: 1fr !important; gap: 28px !important; }
  .pillars-grid { grid-template-columns: 1fr !important; }
}
@media (max-width: 640px) {
  h1 { font-size: 44px !important; line-height: 1.08 !important; }
}
</style>
